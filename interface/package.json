{
  "name": "artmind-interface",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:backend": "py -3.11 -m uvicorn server:app --reload --port 8000 --app-dir ../core",
    "dev:full": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
